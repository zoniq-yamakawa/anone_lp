---
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
---

<Layout
  title="招待を受け取りました — あのね"
  description="夫婦ペアリングの招待リンクです。「あのね」アプリをインストールして、招待コードを入力してつながりましょう。"
>
  <div
    style="background:#FBF5EA;color:#3D352C;font-family:'Zen Kaku Gothic New',sans-serif;-webkit-font-smoothing:antialiased;min-height:100vh;display:flex;flex-direction:column"
  >
    <SiteHeader />

    <main style="flex:1;display:flex;align-items:center;justify-content:center;padding:32px">
      <div
        style="max-width:440px;width:100%;background:#FFFFFF;border-radius:32px;padding:48px 36px;text-align:center;box-shadow:0 20px 50px rgba(61,53,44,0.08)"
      >
        <div
          style="width:64px;height:64px;border-radius:20px;background:#FBEAD9;display:flex;align-items:center;justify-content:center;margin:0 auto 24px"
        >
          <span style="font-family:'Zen Maru Gothic',sans-serif;font-weight:900;color:#E07256;font-size:28px">あ</span>
        </div>

        <h1 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:900;font-size:26px;color:#3D352C;margin-bottom:14px">
          ペアのご招待です
        </h1>
        <p style="font-size:15px;line-height:1.9;color:#6E6357;margin-bottom:24px">
          大切な人から「あのね」のペア招待が届きました。<br />アプリを開くか、インストールしてつながりましょう。
        </p>

        <div
          id="invite-code-box"
          style="background:#F6E6D3;border-radius:18px;padding:18px 20px;margin-bottom:28px"
        >
          <div style="font-size:12px;font-weight:700;color:#C2613F;letter-spacing:0.08em;margin-bottom:6px">
            招待コード
          </div>
          <div
            id="invite-code"
            style="font-family:'Zen Maru Gothic',sans-serif;font-weight:900;font-size:24px;letter-spacing:0.12em;color:#3D352C"
          >
            読み込み中…
          </div>
        </div>

        <a
          href="#"
          data-app-store-placeholder
          style="background:#E07256;color:#FFF;text-decoration:none;font-weight:700;font-size:16px;padding:16px 28px;border-radius:999px;display:inline-flex;align-items:center;justify-content:center;gap:9px;width:100%;box-shadow:0 10px 24px rgba(224,114,86,0.32)"
        >
           App Storeで「あのね」を入手
        </a>
        <p style="font-size:13px;color:#9A8B79;margin-top:18px;line-height:1.8">
          すでにインストール済みの方は、このリンクから直接アプリが開きます。
        </p>
      </div>
    </main>

    <SiteFooter background="#FBF5EA" />
  </div>

  <script>
    // Crockford base32: 0-9, A-Z excluding I, L, O, U
    const CODE_PATTERN = /^[0-9A-HJKMNP-TV-Z]{8}$/;

    function extractInviteCode(): string | null {
      const segments = window.location.pathname.split("/").filter(Boolean);
      const last = segments[segments.length - 1];
      if (!last) return null;
      const normalized = last.toUpperCase();
      return CODE_PATTERN.test(normalized) ? normalized : null;
    }

    const codeEl = document.getElementById("invite-code");
    const code = extractInviteCode();

    if (codeEl) {
      codeEl.textContent = code ?? "コードが見つかりません";
    }
  </script>
</Layout>
