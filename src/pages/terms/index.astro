---
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";

const articles = [
  {
    title: "第1条（適用）",
    body: "本規約は、本サービスの利用に関わる一切の関係に適用されます。当社が本サービス上で掲載する個別規定やガイドラインは、本規約の一部を構成します。",
  },
  {
    title: "第2条（利用登録）",
    body: "利用希望者は、当社の定める方法により利用登録を申請し、当社がこれを承認することで利用登録が完了します。当社は、一定の事由があると判断した場合、登録を承認しないことがあります。",
  },
  {
    title: "第3条（アカウントの管理）",
    body: "利用者は、自己の責任においてアカウント情報を管理するものとします。アカウントの管理不十分による損害について、当社は一切の責任を負いません。",
  },
  {
    title: "第4条（禁止事項）",
    body: "利用者は、本サービスの利用にあたり、法令または公序良俗に違反する行為、他の利用者または第三者の権利を侵害する行為、虚偽の情報を登録する行為、本サービスの運営を妨害する行為を行ってはなりません。",
  },
  {
    title: "第5条（本サービスの提供の停止等）",
    body: "当社は、システムの保守点検、天災地変、その他やむを得ない事由がある場合、利用者に事前に通知することなく本サービスの全部または一部の提供を停止することができます。",
  },
  {
    title: "第6条（著作権）",
    body: "利用者が本サービスに投稿した「ひとこと」その他のコンテンツの著作権は、利用者に帰属します。ただし当社は、本サービスの提供・改善に必要な範囲で、これらを無償で利用できるものとします。",
  },
  {
    title: "第7条（免責事項）",
    body: "当社は、本サービスに関して、利用者と他の利用者との間に生じた紛争について一切の責任を負いません。また、本サービスの提供の中断・停止等により利用者に生じた損害について、当社の故意または重過失による場合を除き、責任を負わないものとします。",
  },
  {
    title: "第8条（規約の変更）",
    body: "当社は、必要と判断した場合には、利用者に通知することなく本規約を変更することができます。変更後の本規約は、本サービス上に掲載した時点から効力を生じるものとします。",
  },
  {
    title: "第9条（準拠法・裁判管轄）",
    body: "本規約の解釈にあたっては日本法を準拠法とします。本サービスに関して紛争が生じた場合には、当社の本店所在地を管轄する裁判所を専属的合意管轄とします。",
  },
];
---

<Layout title="利用規約 — あのね" description="あのね株式会社の利用規約です。">
  <div
    style="background:#FBF5EA;color:#3D352C;font-family:'Zen Kaku Gothic New',sans-serif;-webkit-font-smoothing:antialiased;min-height:100vh;display:flex;flex-direction:column"
  >
    <SiteHeader />

    <!-- PAGE HEADER -->
    <section style="background:#F6E6D3;padding:60px 32px 52px">
      <div style="max-width:820px;margin:0 auto">
        <div style="font-size:13px;color:#A8866A;font-weight:500;display:flex;align-items:center;gap:8px">
          <a href="/" style="color:#A8866A;text-decoration:none">ホーム</a><span>›</span><span style="color:#C2613F"
            >利用規約</span
          >
        </div>
        <h1 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:900;font-size:40px;margin:14px 0 0;color:#3D352C">
          利用規約
        </h1>
        <p style="margin:14px 0 0;font-size:15px;color:#8A7E70;line-height:1.9">最終改定日：2026年6月23日</p>
      </div>
    </section>

    <!-- CONTENT -->
    <main style="flex:1;padding:56px 32px 80px">
      <div style="max-width:820px;margin:0 auto">
        <div
          style="display:inline-flex;align-items:center;gap:8px;background:#FBEAD9;color:#C2613F;font-size:12.5px;font-weight:700;padding:7px 14px;border-radius:999px;margin-bottom:30px"
        >
          <span style="width:6px;height:6px;border-radius:50%;background:#E07256"></span>こちらはサンプルです。正式な内容は後ほど差し替えてください。
        </div>

        <p style="font-size:15.5px;line-height:2.1;color:#5A5044;text-wrap:pretty">
          本利用規約（以下「本規約」）は、あのね株式会社（以下「当社」）が提供する家族向けひとこと日記アプリ「あのね」（以下「本サービス」）の利用条件を定めるものです。利用者は、本規約に同意のうえ本サービスをご利用ください。
        </p>

        <div style="margin-top:38px;display:flex;flex-direction:column;gap:30px">
          {articles.map((article) => (
            <div>
              <h2 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:700;font-size:20px;color:#3D352C;margin-bottom:12px">
                {article.title}
              </h2>
              <p style="font-size:15.5px;line-height:2.1;color:#5A5044;text-wrap:pretty">{article.body}</p>
            </div>
          ))}
        </div>
      </div>
    </main>

    <SiteFooter current="terms" background="#FBF5EA" />
  </div>
</Layout>
