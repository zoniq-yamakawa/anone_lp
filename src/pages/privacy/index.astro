---
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";

const sections = [
  {
    title: "取得する情報",
    body: "当社は、本サービスの提供にあたり、お名前、メールアドレス、プロフィール画像、投稿された「ひとこと」の内容、端末情報、利用状況に関する情報などを取得することがあります。",
  },
  {
    title: "利用目的",
    body: "取得した情報は、本サービスの提供・本人確認・お問い合わせ対応・機能改善・利用規約に違反する行為への対応・重要なお知らせの通知のために利用します。これらの目的の範囲を超えて利用することはありません。",
  },
  {
    title: "第三者への提供",
    body: "当社は、法令に基づく場合を除き、あらかじめ利用者の同意を得ることなく、個人情報を第三者に提供しません。投稿された「ひとこと」は、利用者が招待した家族グループのメンバーのみに共有されます。",
  },
  {
    title: "安全管理措置",
    body: "当社は、個人情報の漏えい・滅失・毀損の防止その他の安全管理のために、通信の暗号化、アクセス権限の管理など、必要かつ適切な措置を講じます。",
  },
  {
    title: "開示・訂正・削除のご請求",
    body: "利用者は、当社の保有する自己の個人情報について、開示・訂正・利用停止・削除を求めることができます。ご請求の際は、本ポリシー末尾のお問い合わせ窓口までご連絡ください。",
  },
  {
    title: "Cookie等の利用",
    body: "本サービスでは、利便性の向上や利用状況の把握のためにCookieや類似技術を利用することがあります。利用者はブラウザ設定によりこれらを無効化できますが、一部機能が利用できなくなる場合があります。",
  },
  {
    title: "本ポリシーの改定",
    body: "当社は、法令の変更やサービス内容の変更に応じて、本ポリシーを改定することがあります。重要な変更がある場合には、本サービス上でお知らせします。",
  },
];
---

<Layout title="プライバシーポリシー — あのね" description="あのね株式会社のプライバシーポリシーです。">
  <div
    style="background:#FBF5EA;color:#3D352C;font-family:'Zen Kaku Gothic New',sans-serif;-webkit-font-smoothing:antialiased;min-height:100vh;display:flex;flex-direction:column"
  >
    <SiteHeader />

    <!-- PAGE HEADER -->
    <section style="background:#F6E6D3;padding:60px 32px 52px">
      <div style="max-width:820px;margin:0 auto">
        <div style="font-size:13px;color:#A8866A;font-weight:500;display:flex;align-items:center;gap:8px">
          <a href="/" style="color:#A8866A;text-decoration:none">ホーム</a><span>›</span><span style="color:#C2613F"
            >プライバシーポリシー</span
          >
        </div>
        <h1 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:900;font-size:40px;margin:14px 0 0;color:#3D352C">
          プライバシーポリシー
        </h1>
        <p style="margin:14px 0 0;font-size:15px;color:#8A7E70;line-height:1.9">最終改定日：2026年6月23日</p>
      </div>
    </section>

    <!-- CONTENT -->
    <main style="flex:1;padding:56px 32px 80px">
      <div style="max-width:820px;margin:0 auto">
        <div
          style="display:inline-flex;align-items:center;gap:8px;background:#FBEAD9;color:#C2613F;font-size:12.5px;font-weight:700;padding:7px 14px;border-radius:999px;margin-bottom:30px"
        >
          <span style="width:6px;height:6px;border-radius:50%;background:#E07256"></span>こちらはサンプルです。正式な内容は後ほど差し替えてください。
        </div>

        <p style="font-size:15.5px;line-height:2.1;color:#5A5044;text-wrap:pretty">
          あのね株式会社（以下「当社」）は、家族向けひとこと日記アプリ「あのね」（以下「本サービス」）における利用者の個人情報の取扱いについて、以下のとおりプライバシーポリシー（以下「本ポリシー」）を定めます。
        </p>

        <div style="margin-top:38px;display:flex;flex-direction:column;gap:34px">
          {sections.map((section, i) => (
            <div>
              <h2
                style="font-family:'Zen Maru Gothic',sans-serif;font-weight:700;font-size:21px;color:#3D352C;display:flex;align-items:center;gap:12px;margin-bottom:14px"
              >
                <span
                  style="width:30px;height:30px;flex:none;border-radius:9px;background:#FBEAD9;color:#E07256;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:900"
                  >{i + 1}</span
                >{section.title}
              </h2>
              <p style="font-size:15.5px;line-height:2.1;color:#5A5044;text-wrap:pretty">{section.body}</p>
            </div>
          ))}

          <div style="background:#FFFFFF;border-radius:20px;padding:28px 30px;box-shadow:0 10px 26px rgba(61,53,44,0.05)">
            <h2 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:700;font-size:19px;color:#3D352C;margin-bottom:12px">
              お問い合わせ窓口
            </h2>
            <p style="font-size:15px;line-height:1.95;color:#5A5044">
              あのね株式会社　個人情報保護担当<br />メール：privacy@anone.example<br /><a
                href="/contact"
                style="color:#C2613F;font-weight:700;text-decoration:none">お問い合わせフォームはこちら →</a
              >
            </p>
          </div>
        </div>
      </div>
    </main>

    <SiteFooter current="privacy" background="#FBF5EA" />
  </div>
</Layout>
