---
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
---

<Layout title="運営会社 — あのね" description="あのねを運営する会社についてご案内します。">
  <div
    style="background:#FBF5EA;color:#3D352C;font-family:'Zen Kaku Gothic New',sans-serif;-webkit-font-smoothing:antialiased;min-height:100vh;display:flex;flex-direction:column"
  >
    <SiteHeader />

    <!-- PAGE HEADER -->
    <section style="background:#F6E6D3;padding:60px 32px 52px">
      <div style="max-width:860px;margin:0 auto">
        <div style="font-size:13px;color:#A8866A;font-weight:500;display:flex;align-items:center;gap:8px">
          <a href="/" style="color:#A8866A;text-decoration:none">ホーム</a><span>›</span><span style="color:#C2613F"
            >運営会社</span
          >
        </div>
        <h1 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:900;font-size:40px;margin:14px 0 0;color:#3D352C">
          運営会社
        </h1>
        <p style="margin:14px 0 0;font-size:16px;color:#6E6357;line-height:1.9">あのねを運営する会社についてご案内します。</p>
      </div>
    </section>

    <!-- CONTENT -->
    <main style="flex:1;padding:56px 32px 80px">
      <div style="max-width:860px;margin:0 auto">
        <div
          style="display:inline-flex;align-items:center;gap:8px;background:#FBEAD9;color:#C2613F;font-size:12.5px;font-weight:700;padding:7px 14px;border-radius:999px;margin-bottom:28px"
        >
          <span style="width:6px;height:6px;border-radius:50%;background:#E07256"></span>こちらはサンプルです。正式な情報は後ほど差し替えてください。
        </div>

        <div style="background:#FFFFFF;border-radius:24px;box-shadow:0 12px 30px rgba(61,53,44,0.05);overflow:hidden">
          <dl style="margin:0">
            <div style="display:grid;grid-template-columns:200px 1fr;gap:0;border-bottom:1px solid #F1E7D6">
              <dt style="padding:22px 28px;font-weight:700;font-size:15px;color:#3D352C;background:#FCF7EE">会社名</dt>
              <dd style="padding:22px 28px;font-size:15px;color:#5A5044;line-height:1.8">あのね株式会社（Anone Inc.）</dd>
            </div>
            <div style="display:grid;grid-template-columns:200px 1fr;gap:0;border-bottom:1px solid #F1E7D6">
              <dt style="padding:22px 28px;font-weight:700;font-size:15px;color:#3D352C;background:#FCF7EE">設立</dt>
              <dd style="padding:22px 28px;font-size:15px;color:#5A5044;line-height:1.8">2024年4月1日</dd>
            </div>
            <div style="display:grid;grid-template-columns:200px 1fr;gap:0;border-bottom:1px solid #F1E7D6">
              <dt style="padding:22px 28px;font-weight:700;font-size:15px;color:#3D352C;background:#FCF7EE">代表者</dt>
              <dd style="padding:22px 28px;font-size:15px;color:#5A5044;line-height:1.8">代表取締役　あの ね子</dd>
            </div>
            <div style="display:grid;grid-template-columns:200px 1fr;gap:0;border-bottom:1px solid #F1E7D6">
              <dt style="padding:22px 28px;font-weight:700;font-size:15px;color:#3D352C;background:#FCF7EE">所在地</dt>
              <dd style="padding:22px 28px;font-size:15px;color:#5A5044;line-height:1.8">
                〒150-0001<br />東京都渋谷区神宮前1-2-3　あのねビル 5F
              </dd>
            </div>
            <div style="display:grid;grid-template-columns:200px 1fr;gap:0;border-bottom:1px solid #F1E7D6">
              <dt style="padding:22px 28px;font-weight:700;font-size:15px;color:#3D352C;background:#FCF7EE">資本金</dt>
              <dd style="padding:22px 28px;font-size:15px;color:#5A5044;line-height:1.8">5,000万円</dd>
            </div>
            <div style="display:grid;grid-template-columns:200px 1fr;gap:0;border-bottom:1px solid #F1E7D6">
              <dt style="padding:22px 28px;font-weight:700;font-size:15px;color:#3D352C;background:#FCF7EE">事業内容</dt>
              <dd style="padding:22px 28px;font-size:15px;color:#5A5044;line-height:1.8">
                家族向けひとこと日記アプリ「あのね」の企画・開発・運営
              </dd>
            </div>
            <div style="display:grid;grid-template-columns:200px 1fr;gap:0;border-bottom:1px solid #F1E7D6">
              <dt style="padding:22px 28px;font-weight:700;font-size:15px;color:#3D352C;background:#FCF7EE">従業員数</dt>
              <dd style="padding:22px 28px;font-size:15px;color:#5A5044;line-height:1.8">24名（2026年6月現在）</dd>
            </div>
            <div style="display:grid;grid-template-columns:200px 1fr;gap:0">
              <dt style="padding:22px 28px;font-weight:700;font-size:15px;color:#3D352C;background:#FCF7EE">お問い合わせ</dt>
              <dd style="padding:22px 28px;font-size:15px;color:#5A5044;line-height:1.8">
                hello@anone.example<br /><a
                  href="/contact"
                  style="color:#C2613F;font-weight:700;text-decoration:none">お問い合わせフォームはこちら →</a
                >
              </dd>
            </div>
          </dl>
        </div>

        <div style="margin-top:40px">
          <h2 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:700;font-size:22px;color:#3D352C;margin-bottom:14px">
            わたしたちのこと
          </h2>
          <p style="font-size:15.5px;line-height:2.05;color:#5A5044;text-wrap:pretty">
            あのねは「離れていても、何気ない一日を分け合える家族でいたい」という思いから生まれました。立派な言葉でなくていい、たったひとことで、人はつながっていられる——そんな小さな仕組みを、これからも丁寧につくっていきます。
          </p>
        </div>
      </div>
    </main>

    <SiteFooter current="company" background="#FBF5EA" />
  </div>
</Layout>
