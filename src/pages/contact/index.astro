---
import Layout from "../../layouts/Layout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
---

<Layout title="お問い合わせ — あのね" description="あのねへのご質問・ご要望・不具合のご報告はこちらから。">
  <div
    style="background:#FBF5EA;color:#3D352C;font-family:'Zen Kaku Gothic New',sans-serif;-webkit-font-smoothing:antialiased;min-height:100vh;display:flex;flex-direction:column"
  >
    <SiteHeader />

    <!-- PAGE HEADER -->
    <section style="background:#F6E6D3;padding:60px 32px 52px">
      <div style="max-width:820px;margin:0 auto">
        <div style="font-size:13px;color:#A8866A;font-weight:500;display:flex;align-items:center;gap:8px">
          <a href="/" style="color:#A8866A;text-decoration:none">ホーム</a><span>›</span><span style="color:#C2613F"
            >お問い合わせ</span
          >
        </div>
        <h1 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:900;font-size:40px;margin:14px 0 0;color:#3D352C">
          お問い合わせ
        </h1>
        <p style="margin:14px 0 0;font-size:16px;color:#6E6357;line-height:1.9">
          ご質問・ご要望・不具合のご報告など、お気軽にお寄せください。<br />通常3営業日以内にご返信いたします。
        </p>
      </div>
    </section>

    <!-- CONTENT -->
    <main style="flex:1;padding:56px 32px 80px">
      <div style="max-width:820px;margin:0 auto;display:grid;grid-template-columns:1.4fr 0.85fr;gap:40px;align-items:start">
        <!-- FORM -->
        <div>
          <div
            style="display:inline-flex;align-items:center;gap:8px;background:#FBEAD9;color:#C2613F;font-size:12.5px;font-weight:700;padding:7px 14px;border-radius:999px;margin-bottom:24px"
          >
            <span style="width:6px;height:6px;border-radius:50%;background:#E07256"></span>サンプルフォームです。送信先は後ほど設定してください。
          </div>

          <div
            id="contact-success"
            style="display:none;background:#FFFFFF;border-radius:24px;padding:44px 36px;box-shadow:0 12px 30px rgba(61,53,44,0.05);text-align:center"
          >
            <div
              style="width:64px;height:64px;border-radius:50%;background:#E7F0DD;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;font-size:30px;color:#7FA06A;font-weight:900"
            >
              ✓
            </div>
            <h2 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:700;font-size:24px;color:#3D352C;margin-bottom:12px">
              送信しました
            </h2>
            <p style="font-size:15px;line-height:2;color:#6E6357">
              お問い合わせありがとうございます。<br />内容を確認のうえ、ご返信いたします。
            </p>
            <button
              id="contact-reset"
              type="button"
              style="margin-top:24px;background:none;border:none;color:#C2613F;font-weight:700;font-size:14px;cursor:pointer;font-family:inherit"
              >もう一度送信する</button
            >
          </div>

          <form
            id="contact-form"
            style="background:#FFFFFF;border-radius:24px;padding:34px 32px;box-shadow:0 12px 30px rgba(61,53,44,0.05);display:flex;flex-direction:column;gap:22px"
          >
            <div style="display:flex;flex-direction:column;gap:9px">
              <label style="font-size:14px;font-weight:700;color:#3D352C">お名前 <span style="color:#E07256">＊</span></label>
              <input
                class="anone-field"
                type="text"
                required
                placeholder="あの ね子"
                style="font-family:inherit;font-size:15px;color:#3D352C;padding:13px 15px;border:1.5px solid #ECE0CE;border-radius:13px;background:#FCF9F2;transition:.15s"
              />
            </div>

            <div style="display:flex;flex-direction:column;gap:9px">
              <label style="font-size:14px;font-weight:700;color:#3D352C"
                >メールアドレス <span style="color:#E07256">＊</span></label
              >
              <input
                class="anone-field"
                type="email"
                required
                placeholder="you@example.com"
                style="font-family:inherit;font-size:15px;color:#3D352C;padding:13px 15px;border:1.5px solid #ECE0CE;border-radius:13px;background:#FCF9F2;transition:.15s"
              />
            </div>

            <div style="display:flex;flex-direction:column;gap:9px">
              <label style="font-size:14px;font-weight:700;color:#3D352C">お問い合わせ種別</label>
              <select
                class="anone-field"
                style="font-family:inherit;font-size:15px;color:#3D352C;padding:13px 15px;border:1.5px solid #ECE0CE;border-radius:13px;background:#FCF9F2;transition:.15s;appearance:none"
              >
                <option>ご利用方法について</option>
                <option>不具合のご報告</option>
                <option>ご要望・ご意見</option>
                <option>取材・お仕事のご相談</option>
                <option>その他</option>
              </select>
            </div>

            <div style="display:flex;flex-direction:column;gap:9px">
              <label style="font-size:14px;font-weight:700;color:#3D352C"
                >お問い合わせ内容 <span style="color:#E07256">＊</span></label
              >
              <textarea
                class="anone-field"
                required
                rows="5"
                placeholder="あのね、こんなことで困っていて…"
                style="font-family:inherit;font-size:15px;color:#3D352C;padding:13px 15px;border:1.5px solid #ECE0CE;border-radius:13px;background:#FCF9F2;transition:.15s;resize:vertical;line-height:1.7"
              ></textarea>
            </div>

            <label style="display:flex;align-items:flex-start;gap:10px;font-size:13.5px;color:#6E6357;line-height:1.7">
              <input type="checkbox" required style="margin-top:3px;width:16px;height:16px;accent-color:#E07256;flex:none" />
              <span><a href="/privacy" style="color:#C2613F;font-weight:700;text-decoration:none">プライバシーポリシー</a>に同意します</span>
            </label>

            <button
              type="submit"
              style="background:#E07256;color:#FFF;border:none;font-family:'Zen Maru Gothic',sans-serif;font-weight:700;font-size:16px;padding:16px;border-radius:14px;cursor:pointer;box-shadow:0 10px 24px rgba(224,114,86,0.3)"
              >この内容で送信する</button
            >
          </form>
        </div>

        <!-- ASIDE -->
        <aside style="display:flex;flex-direction:column;gap:18px">
          <div style="background:#FBEFE0;border-radius:20px;padding:26px 24px">
            <h3 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:700;font-size:17px;color:#3D352C;margin-bottom:10px">
              メールでのお問い合わせ
            </h3>
            <p style="font-size:14px;line-height:1.9;color:#6E6357">support@anone.example<br />受付時間：平日 10:00–18:00</p>
          </div>
          <div style="background:#FFFFFF;border-radius:20px;padding:26px 24px;box-shadow:0 10px 26px rgba(61,53,44,0.05)">
            <h3 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:700;font-size:17px;color:#3D352C;margin-bottom:10px">
              よくあるご質問
            </h3>
            <p style="font-size:14px;line-height:1.9;color:#6E6357;margin-bottom:12px">
              お問い合わせの前に、よくあるご質問もご確認ください。
            </p>
            <a href="/" style="color:#C2613F;font-weight:700;font-size:14px;text-decoration:none">ヘルプを見る →</a>
          </div>
        </aside>
      </div>
    </main>

    <SiteFooter current="contact" background="#FBF5EA" />
  </div>

  <style>
    .anone-field::placeholder {
      color: #b4a897;
    }
    .anone-field:focus {
      outline: none;
      border-color: #e07256;
      box-shadow: 0 0 0 3px rgba(224, 114, 86, 0.14);
    }
  </style>

  <script>
    const form = document.getElementById("contact-form") as HTMLFormElement | null;
    const success = document.getElementById("contact-success");
    const resetButton = document.getElementById("contact-reset");

    form?.addEventListener("submit", (e) => {
      e.preventDefault();
      form.style.display = "none";
      if (success) success.style.display = "block";
    });

    resetButton?.addEventListener("click", () => {
      if (success) success.style.display = "none";
      if (form) {
        form.reset();
        form.style.display = "flex";
      }
    });
  </script>
</Layout>
