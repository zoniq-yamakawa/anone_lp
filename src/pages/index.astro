---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
---

<Layout title="あのね — 大切な人と、1日ひとこと">
  <div
    style="background:#FBF5EA;color:#3D352C;font-family:'Zen Kaku Gothic New',sans-serif;-webkit-font-smoothing:antialiased;overflow-x:hidden"
  >
    <SiteHeader />

    <!-- HERO -->
    <section
      style="position:relative;max-width:1160px;margin:0 auto;padding:64px 32px 80px;display:grid;grid-template-columns:1.05fr 0.95fr;gap:40px;align-items:center"
    >
      <div
        style="position:absolute;top:40px;right:120px;width:340px;height:340px;border-radius:46% 54% 58% 42%/52% 44% 56% 48%;background:#F4D9B8;opacity:0.55;filter:blur(2px);z-index:0;animation:anone-blob 9s ease-in-out infinite"
      >
      </div>
      <div
        style="position:absolute;bottom:30px;right:340px;width:170px;height:170px;border-radius:50%;background:#CBD9B8;opacity:0.5;z-index:0;animation:anone-blob 11s ease-in-out infinite"
      >
      </div>

      <div style="position:relative;z-index:2">
        <div
          style="display:inline-flex;align-items:center;gap:8px;background:#FFF;border:1px solid rgba(61,53,44,0.08);padding:7px 15px;border-radius:999px;font-size:13px;font-weight:700;color:#C2613F;box-shadow:0 4px 14px rgba(61,53,44,0.04)"
        >
          <span style="width:7px;height:7px;border-radius:50%;background:#7FA06A"></span>家族をつなぐ、ひとこと日記
        </div>
        <h1
          style="font-family:'Zen Maru Gothic',sans-serif;font-weight:900;font-size:58px;line-height:1.32;letter-spacing:0.01em;margin:24px 0 0;color:#3D352C;text-wrap:balance"
        >
          大切な人と、<br /><span style="color:#E07256">1日ひとこと</span>。
        </h1>
        <p style="margin:26px 0 0;font-size:18px;line-height:2;color:#6E6357;max-width:430px;text-wrap:pretty">
          「あのね、今日ね——」<br />その小さなはじまりを、毎日ひとつ。離れて暮らす家族と、何気ない一日をそっと分け合えるアプリです。
        </p>
        <div style="display:flex;align-items:center;gap:14px;margin-top:34px">
          <a
            href="#cta"
            style="background:#E07256;color:#FFF;text-decoration:none;font-weight:700;font-size:17px;padding:16px 30px;border-radius:999px;box-shadow:0 10px 24px rgba(224,114,86,0.32)"
            >無料ではじめる</a
          >
          <a
            href="#feature"
            style="color:#3D352C;text-decoration:none;font-weight:700;font-size:16px;padding:16px 8px;display:inline-flex;align-items:center;gap:8px"
            >アプリを見る<span style="color:#E07256">→</span></a
          >
        </div>
        <div style="display:flex;align-items:center;gap:18px;margin-top:30px">
          <div style="display:flex">
            <div
              style="width:38px;height:38px;border-radius:50%;background:#E8A24C;border:3px solid #FBF5EA;display:flex;align-items:center;justify-content:center;color:#FFF;font-weight:700;font-size:14px"
            >
              み
            </div>
            <div
              style="width:38px;height:38px;border-radius:50%;background:#7FA06A;border:3px solid #FBF5EA;margin-left:-12px;display:flex;align-items:center;justify-content:center;color:#FFF;font-weight:700;font-size:14px"
            >
              母
            </div>
            <div
              style="width:38px;height:38px;border-radius:50%;background:#D98162;border:3px solid #FBF5EA;margin-left:-12px;display:flex;align-items:center;justify-content:center;color:#FFF;font-weight:700;font-size:13px"
            >
              祖
            </div>
          </div>
          <span style="font-size:14px;color:#8A7E70;line-height:1.6"
            >家族みんなで、もう<strong style="color:#3D352C">12万世帯</strong>が<br />ひとことを交わしています</span
          >
        </div>
      </div>

      <!-- PHONE -->
      <div style="position:relative;z-index:2;display:flex;justify-content:center">
        <div
          style="width:300px;background:#2E2620;border-radius:44px;padding:11px;box-shadow:0 36px 70px rgba(61,53,44,0.28);animation:anone-float 7s ease-in-out infinite"
        >
          <div style="background:#FCF7EE;border-radius:34px;overflow:hidden">
            <div
              style="display:flex;justify-content:space-between;align-items:center;padding:14px 22px 6px;font-size:12px;font-weight:700;color:#3D352C"
            >
              <span>9:41</span>
              <span style="display:flex;gap:5px;align-items:center"
                ><span
                  style="width:16px;height:9px;border:1.5px solid #3D352C;border-radius:3px;display:inline-block"
                ></span></span
              >
            </div>
            <div style="padding:8px 20px 16px">
              <div style="display:flex;align-items:center;justify-content:space-between">
                <span style="font-family:'Zen Maru Gothic',sans-serif;font-weight:900;font-size:20px;color:#E07256"
                  >あのね</span
                >
                <span style="font-size:12px;color:#A89C8C;font-weight:500">6月23日 火</span>
              </div>
            </div>
            <div style="padding:0 16px 18px;display:flex;flex-direction:column;gap:11px">
              <div
                style="background:#FFFFFF;border-radius:20px 20px 20px 6px;padding:14px 15px;box-shadow:0 4px 14px rgba(61,53,44,0.05)"
              >
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:7px">
                  <span
                    style="width:26px;height:26px;border-radius:50%;background:#E8A24C;color:#FFF;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px"
                    >み</span
                  >
                  <span style="font-weight:700;font-size:13px;color:#3D352C">みさき</span>
                  <span style="font-size:11px;color:#B4A897;margin-left:auto">16:20</span>
                </div>
                <p style="font-size:13.5px;line-height:1.7;color:#4A4138">
                  あのね、今日ね、<strong style="color:#E07256;font-weight:700">逆上がりができた</strong>よ！
                </p>
                <div style="display:flex;gap:6px;margin-top:9px">
                  <span style="font-size:11px;background:#FBEAD9;color:#C2613F;padding:3px 9px;border-radius:999px;font-weight:700"
                    >❤ 2</span
                  >
                </div>
              </div>

              <div
                style="background:#FFFFFF;border-radius:20px 20px 20px 6px;padding:14px 15px;box-shadow:0 4px 14px rgba(61,53,44,0.05)"
              >
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:7px">
                  <span
                    style="width:26px;height:26px;border-radius:50%;background:#7FA06A;color:#FFF;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:12px"
                    >母</span
                  >
                  <span style="font-weight:700;font-size:13px;color:#3D352C">おかあさん</span>
                  <span style="font-size:11px;color:#B4A897;margin-left:auto">18:02</span>
                </div>
                <p style="font-size:13.5px;line-height:1.7;color:#4A4138">おかえり。ずっと練習してたもんね、すごいね。</p>
              </div>

              <div style="background:#FBEFE0;border-radius:20px 20px 6px 20px;padding:14px 15px;border:1px dashed #E6C9A6">
                <div style="display:flex;align-items:center;gap:8px;margin-bottom:7px">
                  <span
                    style="width:26px;height:26px;border-radius:50%;background:#D98162;color:#FFF;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:11px"
                    >祖</span
                  >
                  <span style="font-weight:700;font-size:13px;color:#3D352C">じいじ</span>
                  <span style="font-size:11px;color:#B4A897;margin-left:auto">いま入力中…</span>
                </div>
                <p style="font-size:13.5px;line-height:1.7;color:#9A8B79">今度じいじにも見せて——</p>
              </div>
            </div>
            <div
              style="padding:11px 16px 16px;border-top:1px solid rgba(61,53,44,0.06);display:flex;align-items:center;gap:10px"
            >
              <div style="flex:1;background:#F1E7D6;border-radius:999px;padding:11px 16px;font-size:13px;color:#A89C8C">
                あのね、今日は…
              </div>
              <div
                style="width:40px;height:40px;border-radius:50%;background:#E07256;display:flex;align-items:center;justify-content:center;color:#FFF;font-size:18px;flex:none"
              >
                ↑
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 共感 -->
    <section style="background:#F6E6D3;padding:88px 32px">
      <div style="max-width:760px;margin:0 auto;text-align:center">
        <span style="font-family:'Zen Maru Gothic',sans-serif;font-weight:700;color:#C2613F;font-size:15px;letter-spacing:0.08em"
          >ANONE</span
        >
        <h2
          style="font-family:'Zen Maru Gothic',sans-serif;font-weight:900;font-size:38px;line-height:1.7;margin:18px 0 0;color:#3D352C;text-wrap:balance"
        >
          「元気にしてる？」の電話は、<br />少し、かまえてしまう。
        </h2>
        <p style="margin:28px 0 0;font-size:17px;line-height:2.1;color:#6E6357;text-wrap:pretty">
          わざわざ報告するほどじゃない、でも知っていてほしい一日のかけら。<br
          />あのねは、そんな“ひとこと”だけを、いちばん大切な人たちと交わす場所です。<br />返さなくていい。読むだけでいい。それだけで、ちゃんとつながっていられる。
        </p>
      </div>
    </section>

    <!-- 特徴 -->
    <section id="feature" style="max-width:1160px;margin:0 auto;padding:96px 32px 40px">
      <div style="text-align:center;margin-bottom:54px">
        <span style="font-family:'Zen Maru Gothic',sans-serif;font-weight:700;color:#C2613F;font-size:15px;letter-spacing:0.08em"
          >FEATURES</span
        >
        <h2 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:900;font-size:36px;margin:14px 0 0;color:#3D352C">
          つづけられる、3つの理由
        </h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:26px">
        <div style="background:#FFFFFF;border-radius:26px;padding:34px 30px;box-shadow:0 12px 30px rgba(61,53,44,0.05)">
          <div
            style="width:56px;height:56px;border-radius:18px;background:#FBEAD9;display:flex;align-items:center;justify-content:center;margin-bottom:22px"
          >
            <span style="font-family:'Zen Maru Gothic',sans-serif;font-weight:900;color:#E07256;font-size:24px">あ</span>
          </div>
          <h3 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:700;font-size:21px;color:#3D352C;margin-bottom:12px">
            ひとことでいい
          </h3>
          <p style="font-size:15px;line-height:1.95;color:#6E6357;text-wrap:pretty">
            「あのね、」から始める、1日たったひとこと。長い文章も、気のきいた言葉もいらない。今日のかけらを、そのまま。
          </p>
        </div>

        <div style="background:#FFFFFF;border-radius:26px;padding:34px 30px;box-shadow:0 12px 30px rgba(61,53,44,0.05)">
          <div
            style="width:56px;height:56px;border-radius:18px;background:#E7F0DD;display:flex;align-items:center;justify-content:center;margin-bottom:22px"
          >
            <span style="width:18px;height:18px;border:3px solid #7FA06A;border-radius:50%;display:inline-block;position:relative"
              ><span
                style="position:absolute;width:3px;height:9px;background:#7FA06A;border-radius:3px;left:50%;top:-7px;transform:translateX(-50%)"
              ></span></span
            >
          </div>
          <h3 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:700;font-size:21px;color:#3D352C;margin-bottom:12px">
            やさしい通知
          </h3>
          <p style="font-size:15px;line-height:1.95;color:#6E6357;text-wrap:pretty">
            家族がひとこと書くと、そっとお知らせ。せかさず、ためこまず。返事はいらない。読んだら、それで伝わっています。
          </p>
        </div>

        <div style="background:#FFFFFF;border-radius:26px;padding:34px 30px;box-shadow:0 12px 30px rgba(61,53,44,0.05)">
          <div
            style="width:56px;height:56px;border-radius:18px;background:#FBEFD9;display:flex;align-items:center;justify-content:center;margin-bottom:22px"
          >
            <span style="display:flex;gap:3px;align-items:flex-end"
              ><span style="width:5px;height:12px;background:#E8A24C;border-radius:2px"></span
              ><span style="width:5px;height:18px;background:#E8A24C;border-radius:2px"></span
              ><span style="width:5px;height:24px;background:#E8A24C;border-radius:2px"></span></span
            >
          </div>
          <h3 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:700;font-size:21px;color:#3D352C;margin-bottom:12px">
            ずっと残る
          </h3>
          <p style="font-size:15px;line-height:1.95;color:#6E6357;text-wrap:pretty">
            何気ない毎日が、めくれる思い出に。1年後、ひとことを並べて読み返すと、家族の歩みがそこにあります。
          </p>
        </div>
      </div>
    </section>

    <!-- 使い方 -->
    <section id="how" style="max-width:1160px;margin:0 auto;padding:72px 32px 40px">
      <div style="text-align:center;margin-bottom:54px">
        <span style="font-family:'Zen Maru Gothic',sans-serif;font-weight:700;color:#C2613F;font-size:15px;letter-spacing:0.08em"
          >HOW IT WORKS</span
        >
        <h2 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:900;font-size:36px;margin:14px 0 0;color:#3D352C">
          はじめ方は、3ステップ
        </h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:26px">
        <div style="text-align:center;padding:0 14px">
          <div style="font-family:'Zen Maru Gothic',sans-serif;font-weight:900;font-size:46px;color:#EAD7BE;line-height:1">
            01
          </div>
          <h3 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:700;font-size:20px;color:#3D352C;margin:10px 0 10px">
            家族を招く
          </h3>
          <p style="font-size:14.5px;line-height:1.95;color:#6E6357;text-wrap:pretty">
            招待リンクをLINEで送るだけ。スマホが得意でなくても、すぐにつながれます。
          </p>
        </div>

        <div style="text-align:center;padding:0 14px;border-left:1px solid #ECDFC9;border-right:1px solid #ECDFC9">
          <div style="font-family:'Zen Maru Gothic',sans-serif;font-weight:900;font-size:46px;color:#EAD7BE;line-height:1">
            02
          </div>
          <h3 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:700;font-size:20px;color:#3D352C;margin:10px 0 10px">
            ひとこと書く
          </h3>
          <p style="font-size:14.5px;line-height:1.95;color:#6E6357;text-wrap:pretty">
            今日あったことを、ひとこと。寝る前の30秒で、その日のかけらを残せます。
          </p>
        </div>

        <div style="text-align:center;padding:0 14px">
          <div style="font-family:'Zen Maru Gothic',sans-serif;font-weight:900;font-size:46px;color:#EAD7BE;line-height:1">
            03
          </div>
          <h3 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:700;font-size:20px;color:#3D352C;margin:10px 0 10px">
            受けとる
          </h3>
          <p style="font-size:14.5px;line-height:1.95;color:#6E6357;text-wrap:pretty">
            大切な人のひとことが、毎日そっと届く。離れていても、今日がとなりにあります。
          </p>
        </div>
      </div>
    </section>

    <!-- お客様の声 -->
    <section id="voice" style="background:#F6E6D3;padding:90px 32px;margin-top:56px">
      <div style="max-width:1160px;margin:0 auto">
        <div style="text-align:center;margin-bottom:50px">
          <span style="font-family:'Zen Maru Gothic',sans-serif;font-weight:700;color:#C2613F;font-size:15px;letter-spacing:0.08em"
            >VOICES</span
          >
          <h2 style="font-family:'Zen Maru Gothic',sans-serif;font-weight:900;font-size:36px;margin:14px 0 0;color:#3D352C">
            あのねのある毎日
          </h2>
        </div>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px">
          <div style="background:#FFFFFF;border-radius:24px;padding:30px 28px;box-shadow:0 10px 26px rgba(61,53,44,0.05)">
            <p style="font-size:15.5px;line-height:2;color:#4A4138;text-wrap:pretty">
              単身赴任で離れていても、娘の「あのね」が毎晩届くだけで救われます。電話より、これがちょうどいい。
            </p>
            <div style="display:flex;align-items:center;gap:11px;margin-top:22px">
              <span
                style="width:42px;height:42px;border-radius:50%;background:#D98162;color:#FFF;display:flex;align-items:center;justify-content:center;font-weight:700"
                >T</span
              >
              <div>
                <div style="font-weight:700;font-size:14px;color:#3D352C">たかしさん</div>
                <div style="font-size:12.5px;color:#9A8B79">40代・父</div>
              </div>
            </div>
          </div>

          <div style="background:#FFFFFF;border-radius:24px;padding:30px 28px;box-shadow:0 10px 26px rgba(61,53,44,0.05)">
            <p style="font-size:15.5px;line-height:2;color:#4A4138;text-wrap:pretty">
              実家の母とつないでいます。「庭の花が咲いた」みたいな何でもない話が、いちばんうれしいんですよね。
            </p>
            <div style="display:flex;align-items:center;gap:11px;margin-top:22px">
              <span
                style="width:42px;height:42px;border-radius:50%;background:#7FA06A;color:#FFF;display:flex;align-items:center;justify-content:center;font-weight:700"
                >Y</span
              >
              <div>
                <div style="font-weight:700;font-size:14px;color:#3D352C">ゆきこさん</div>
                <div style="font-size:12.5px;color:#9A8B79">30代・娘</div>
              </div>
            </div>
          </div>

          <div style="background:#FFFFFF;border-radius:24px;padding:30px 28px;box-shadow:0 10px 26px rgba(61,53,44,0.05)">
            <p style="font-size:15.5px;line-height:2;color:#4A4138;text-wrap:pretty">
              孫のひとことを読むのが一日の楽しみ。返事は短くていいというのが、年寄りには本当にありがたい。
            </p>
            <div style="display:flex;align-items:center;gap:11px;margin-top:22px">
              <span
                style="width:42px;height:42px;border-radius:50%;background:#E8A24C;color:#FFF;display:flex;align-items:center;justify-content:center;font-weight:700"
                >K</span
              >
              <div>
                <div style="font-weight:700;font-size:14px;color:#3D352C">かずえさん</div>
                <div style="font-size:12.5px;color:#9A8B79">60代・祖母</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section id="cta" style="padding:96px 32px">
      <div
        style="max-width:880px;margin:0 auto;background:#E07256;border-radius:36px;padding:64px 48px;text-align:center;position:relative;overflow:hidden;box-shadow:0 26px 60px rgba(224,114,86,0.32)"
      >
        <div
          style="position:absolute;top:-50px;right:-30px;width:200px;height:200px;border-radius:50%;background:rgba(255,255,255,0.1)"
        >
        </div>
        <div
          style="position:absolute;bottom:-70px;left:-40px;width:240px;height:240px;border-radius:50%;background:rgba(255,255,255,0.08)"
        >
        </div>
        <h2
          style="position:relative;font-family:'Zen Maru Gothic',sans-serif;font-weight:900;font-size:42px;color:#FFF;line-height:1.5;margin-bottom:18px"
        >
          今日から、あのね。
        </h2>
        <p style="position:relative;font-size:17px;color:rgba(255,255,255,0.92);line-height:1.9;margin-bottom:34px">
          ダウンロードは無料。今夜のひとことから、はじめられます。
        </p>
        <div style="position:relative;display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
          <a
            href="#"
            style="background:#FFFFFF;color:#3D352C;text-decoration:none;font-weight:700;font-size:15px;padding:15px 28px;border-radius:999px;display:inline-flex;align-items:center;gap:9px;box-shadow:0 8px 20px rgba(0,0,0,0.12)"
            ><span style="font-size:20px"></span>App Store</a
          >
          <a
            href="#"
            style="background:#3D352C;color:#FFF;text-decoration:none;font-weight:700;font-size:15px;padding:15px 28px;border-radius:999px;display:inline-flex;align-items:center;gap:9px;box-shadow:0 8px 20px rgba(0,0,0,0.18)"
            ><span style="font-size:18px">▶</span>Google Play</a
          >
        </div>
      </div>
    </section>

    <SiteFooter />
  </div>
</Layout>
